# ===========================================
# Frontend Environment Variables (Example)
# ===========================================
# Copy this file to .env and fill in your actual values.
# Variables must be prefixed with VITE_ to be accessible in the browser.

# LiveKit WebSocket URL for client connection
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Backend URL used to request a LiveKit token
VITE_BACKEND_URL=http://localhost:8000

# Keep false for client demos. Turn on only while debugging LiveKit tracks.
VITE_SHOW_DEBUG_TRACKS=false
VITE_SHOW_AGENT_ACTIVITY=true
